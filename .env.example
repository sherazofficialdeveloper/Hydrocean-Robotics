# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# DATABASE CONFIGURATION
# MONGODB_URI: Connection string for MongoDB (e.g. Atlas cluster or local mongodb instance)
MONGODB_URI=

# SECURITY & SESSION CONFIGURATION
# JWT_SECRET: Strong secret key used for signing JSON Web Tokens
JWT_SECRET=
MAIN_ADMIN_EMAIL_1=
MAIN_ADMIN_EMAIL_2=

# RESEND EMAIL SERVICE CONFIGURATION (REQUIRED FOR RECRUITMENT NOTIFICATIONS & BULK EMAILS)
RESEND_API_KEY=
EMAIL_FROM=

# SMTP NODEMAILER SERVICE CONFIGURATION (PRIMARY AUTHENTICATION EMAILS)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=

# GOOGLE OAUTH CONFIGURATION
# GOOGLE_CLIENT_ID: Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET: Client Secret from Google Cloud Console
GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL: The authorized redirect URI for Google OAuth callback handling
GOOGLE_CALLBACK_URL=

# CLOUDINARY STORAGE CONFIGURATION
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# COMPANY REGISTRATION VERIFICATION
COMPANY_REGISTRATION_URL=https://secp.gov.pk

